# Signzy Configuration
SIGNZY_ENV=sandbox                          # sandbox | production
SIGNZY_API_TOKEN=                           # get from Signzy dashboard
SIGNZY_BASE_URL_SANDBOX=https://api-preproduction.signzy.app/api/v3
SIGNZY_BASE_URL_PRODUCTION=https://api.signzy.app/api/v3

# Fallback mode if Signzy is unreachable
SIGNZY_MOCK_FALLBACK=true                  # true = use mock if API fails

# Surepass.io (Primary Aadhaar OKYC + Face Match + Liveness)
SUREPASS_TOKEN=Bearer YOUR_TOKEN_HERE
SUREPASS_BASE_URL=https://kyc-api.surepass.io/api/v1

# Sandbox.co.in (Secondary - Fallback for Aadhaar OTP)
SANDBOX_API_KEY=your_sandbox_key
SANDBOX_API_SECRET=your_sandbox_secret
